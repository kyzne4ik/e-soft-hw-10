{
  "name": "hw8-knex-prisma",
  "version": "1.0.0",
  "description": "HW8: Knex Query Builder + Prisma ORM",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "knex": "knex --knexfile knexfile.js",
    "migrate": "knex migrate:latest --knexfile knexfile.js",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.js",
    "migrate:make": "knex migrate:make --knexfile knexfile.js",
    "seed": "knex seed:run --knexfile knexfile.js",
    "demo:nplus1": "node src/demos/n-plus-one.js",
    "demo:benchmark": "node src/demos/benchmark.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@prisma/client": "^6.2.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "knex": "^3.2.10",
    "pg": "^8.21.0",
    "prisma": "^6.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "pino-pretty": "^13.0.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
